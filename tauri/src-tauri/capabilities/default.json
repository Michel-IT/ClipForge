{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the ClipForge main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-close",
    "os:allow-locale",
    "os:allow-platform",
    "shell:allow-open",
    "clipboard-manager:allow-read-text",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "store:default",
    "shell:allow-execute",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "binaries/yt-dlp", "sidecar": true, "args": true },
        { "name": "binaries/ffmpeg", "sidecar": true, "args": true }
      ]
    }
  ]
}
