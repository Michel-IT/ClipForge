# Default: text auto-detect, normalize to LF in repo
* text=auto eol=lf

# Always use platform-native line endings for shell scripts
*.sh   text eol=lf
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=crlf

# Source / docs: force LF (consistent across editors)
*.py   text eol=lf
*.md   text eol=lf
*.spec text eol=lf
*.txt  text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Binary assets: do not normalize
*.png   binary
*.ico   binary
*.icns  binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.exe   binary
*.dll   binary
